    P8 --> P9["Adicionar módulos"]
    P9 --> P10["Adicionar água/hidratação"]
    P10 --> P11["Aplicar horários padrão da ala e/ou do paciente"]

    P6 --> P12["Informar glicose, aminoácidos, lipídios, volume total e tempo de infusão"]
    P12 --> P13["Calcular TIG e parâmetros derivados"]

    P4 --> P14["Calcular totais nutricionais"]
    P11 --> P14
    P13 --> P14

    P14 --> P15["Validar regras de segurança e consistência"]
    P15 --> P16["Gerar resumo da terapia nutricional"]
    P16 --> P17["Salvar prescrição"]
    P17 --> P18["Atualizar via ativa do paciente"]
    P18 --> P19["Disponibilizar prescrição para etiquetas, faturamento e monitoramento"]
