{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://shipments-posts-hottest-grab.trycloudflare.com/health"
    },
    {
      "source": "/health/:path*",
      "destination": "https://shipments-posts-hottest-grab.trycloudflare.com/health/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://shipments-posts-hottest-grab.trycloudflare.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
